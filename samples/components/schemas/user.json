{
  "components": {
    "schemas": {
      "Product": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "description": "用户名，3-20位，仅字母/数字/下划线",
            "example": "zhangsan123",
            "default": "hello",
            "enum": [
              "as",
              "bs",
              "ds"
            ],
            "pattern": "^[a-zA-Z0-9_]+$",
            "minLength": 3,
            "maxLength": 20,
            "minimum": 100
          },
          "phone": {
            "type": "string",
            "description": "手机号，11位有效号码",
            "example": "13800138000",
            "pattern": "^1[3-9]\\d{9}$"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "用户邮箱（可选）",
            "example": "zhangsan@xxx.com",
            "nullable": true
          },
          "kaixing": {
            "type": "object",
            "properties": {}
          },
          "jack": {
            "type": "object",
            "properties": {
              "wokan": {
                "type": "string"
              }
            }
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "file": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "size": {
                "type": "integer"
              }
            }
          }
        }
      },
      "user-token": {
        "type": "string",
        "format": "date",
        "default": "abcdefg",
        "nullable": true,
        "minLength": 5,
        "properties": {},
        "example": "ppaadd"
      }
    }
  }
}
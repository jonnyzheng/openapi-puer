{
  "name": "superapi",
  "displayName": "SuperAPI",
  "description": "A Postman-style API development and testing tool for VS Code. Browse, test, and debug OpenAPI endpoints directly in your editor.",
  "version": "0.0.1",
  "publisher": "superapi",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Testing",
    "Other"
  ],
  "keywords": [
    "api",
    "openapi",
    "swagger",
    "rest",
    "http",
    "postman",
    "api-testing",
    "api-client"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "SuperAPI",
      "properties": {
        "superapi.apiDirectory": {
          "type": "string",
          "default": "",
          "description": "Path to the directory containing OpenAPI specification files. If empty, defaults to workspace root."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "superapi",
          "title": "SuperAPI",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "superapi": [
        {
          "id": "superapi.apiExplorer",
          "name": "API Explorer"
        }
      ]
    },
    "commands": [
      {
        "command": "superapi.refresh",
        "title": "Refresh",
        "category": "SuperAPI",
        "icon": "$(refresh)"
      },
      {
        "command": "superapi.openEndpoint",
        "title": "Open Endpoint",
        "category": "SuperAPI"
      },
      {
        "command": "superapi.toggleGroupByTags",
        "title": "Toggle Group by Tags",
        "category": "SuperAPI",
        "icon": "$(list-tree)"
      },
      {
        "command": "superapi.createEnvironment",
        "title": "Create Environment",
        "category": "SuperAPI"
      },
      {
        "command": "superapi.selectEnvironment",
        "title": "Select Environment",
        "category": "SuperAPI"
      },
      {
        "command": "superapi.editEnvironment",
        "title": "Edit Environment",
        "category": "SuperAPI"
      },
      {
        "command": "superapi.setApiFolder",
        "title": "Set API Folder",
        "category": "SuperAPI",
        "icon": "$(folder-opened)"
      },
      {
        "command": "superapi.addFolder",
        "title": "Add Folder",
        "category": "SuperAPI",
        "icon": "$(new-folder)"
      },
      {
        "command": "superapi.addFile",
        "title": "Add File",
        "category": "SuperAPI",
        "icon": "$(new-file)"
      },
      {
        "command": "superapi.deleteItem",
        "title": "Delete",
        "category": "SuperAPI",
        "icon": "$(trash)"
      },
      {
        "command": "superapi.viewSourceCode",
        "title": "View Source Code",
        "category": "SuperAPI",
        "icon": "$(go-to-file)"
      },
      {
        "command": "superapi.addEndpoint",
        "title": "Add Endpoint",
        "category": "SuperAPI",
        "icon": "$(add)"
      },
      {
        "command": "superapi.addModel",
        "title": "Add Schema",
        "category": "SuperAPI",
        "icon": "$(symbol-class)"
      },
      {
        "command": "superapi.addServer",
        "title": "Add Server",
        "category": "SuperAPI",
        "icon": "$(server)"
      },
      {
        "command": "superapi.openInNewTab",
        "title": "Open in New Tab",
        "category": "SuperAPI",
        "icon": "$(split-horizontal)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "superapi.addFolder",
          "when": "view == superapi.apiExplorer",
          "group": "navigation@1"
        },
        {
          "command": "superapi.addFile",
          "when": "view == superapi.apiExplorer",
          "group": "navigation@2"
        },
        {
          "command": "superapi.refresh",
          "when": "view == superapi.apiExplorer",
          "group": "navigation@3"
        },
        {
          "command": "superapi.toggleGroupByTags",
          "when": "view == superapi.apiExplorer",
          "group": "navigation@4"
        },
        {
          "command": "superapi.setApiFolder",
          "when": "view == superapi.apiExplorer",
          "group": "navigation@5"
        }
      ],
      "view/item/context": [
        {
          "command": "superapi.addFolder",
          "when": "view == superapi.apiExplorer && viewItem == folder",
          "group": "1_add@1"
        },
        {
          "command": "superapi.addFile",
          "when": "view == superapi.apiExplorer && viewItem == folder",
          "group": "1_add@2"
        },
        {
          "command": "superapi.deleteItem",
          "when": "view == superapi.apiExplorer && viewItem == folder",
          "group": "2_delete"
        },
        {
          "command": "superapi.deleteItem",
          "when": "view == superapi.apiExplorer && viewItem == file",
          "group": "2_delete"
        },
        {
          "command": "superapi.viewSourceCode",
          "when": "view == superapi.apiExplorer && viewItem == file",
          "group": "1_actions@1"
        },
        {
          "command": "superapi.addEndpoint",
          "when": "view == superapi.apiExplorer && viewItem == file",
          "group": "1_actions@2"
        },
{
          "command": "superapi.viewSourceCode",
          "when": "view == superapi.apiExplorer && viewItem == file-api",
          "group": "1_actions@1"
        },
        {
          "command": "superapi.deleteItem",
          "when": "view == superapi.apiExplorer && viewItem == file-api",
          "group": "2_delete"
        },
        {
          "command": "superapi.viewSourceCode",
          "when": "view == superapi.apiExplorer && viewItem == file-schema",
          "group": "1_actions@1"
        },
        {
          "command": "superapi.addModel",
          "when": "view == superapi.apiExplorer && viewItem == file-schema",
          "group": "1_actions@2"
        },
        {
          "command": "superapi.deleteItem",
          "when": "view == superapi.apiExplorer && viewItem == file-schema",
          "group": "2_delete"
        },
        {
          "command": "superapi.openInNewTab",
          "when": "view == superapi.apiExplorer && viewItem == endpoint",
          "group": "0_open@1"
        },
        {
          "command": "superapi.openInNewTab",
          "when": "view == superapi.apiExplorer && viewItem == file-api",
          "group": "0_open@1"
        },
        {
          "command": "superapi.openInNewTab",
          "when": "view == superapi.apiExplorer && viewItem == file-schema",
          "group": "0_open@1"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "superapi.apiExplorer",
        "contents": "No API folder configured.\n[Set API Folder](command:superapi.setApiFolder)\nSelect a folder containing your OpenAPI specification files to get started."
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile && pnpm run lint",
    "lint": "eslint src --ext ts",
    "test": "vscode-test"
  },
  "packageManager": "pnpm@9.0.0",
  "dependencies": {
    "@apidevtools/swagger-parser": "^10.1.1",
    "@vscode/webview-ui-toolkit": "^1.4.0",
    "axios": "^1.13.4"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "~20.19.31",
    "@types/vscode": "^1.108.1",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vscode/test-cli": "^0.0.4",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^8.57.1",
    "typescript": "^5.9.3"
  }
}

{
  "components": {
    "schemas": {
      "Pet": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier for the pet"
          },
          "name": {
            "type": "string",
            "description": "Name of the pet",
            "minLength": 1,
            "maxLength": 100
          },
          "status": {
            "type": "string",
            "description": "Availability status of the pet",
            "enum": ["available", "pending", "sold"],
            "default": "available"
          },
          "categoryId": {
            "type": ["string", "null"],
            "format": "uuid",
            "description": "ID of the category this pet belongs to"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Tags associated with the pet"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the pet was created"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the pet was last updated"
          }
        },
        "required": ["id", "name", "status", "createdAt", "updatedAt"]
      },
      "CreatePetRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the pet",
            "minLength": 1,
            "maxLength": 100
          },
          "status": {
            "type": "string",
            "description": "Availability status of the pet",
            "enum": ["available", "pending", "sold"],
            "default": "available"
          },
          "categoryId": {
            "type": ["string", "null"],
            "format": "uuid",
            "description": "ID of the category this pet belongs to"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Tags associated with the pet"
          }
        },
        "required": ["name"]
      }
    }
  }
}

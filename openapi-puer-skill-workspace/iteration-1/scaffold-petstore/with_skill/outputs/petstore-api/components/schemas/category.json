{
  "components": {
    "schemas": {
      "Category": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier for the category"
          },
          "name": {
            "type": "string",
            "description": "Name of the category",
            "minLength": 1,
            "maxLength": 50
          },
          "description": {
            "type": "string",
            "description": "Description of the category",
            "maxLength": 255
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the category was created"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the category was last updated"
          }
        },
        "required": ["id", "name", "createdAt", "updatedAt"]
      },
      "CreateCategoryRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the category",
            "minLength": 1,
            "maxLength": 50
          },
          "description": {
            "type": "string",
            "description": "Description of the category",
            "maxLength": 255
          }
        },
        "required": ["name"]
      }
    }
  }
}

{
  "type": "object",
  "title": "Category",
  "description": "A category for pets",
  "required": ["id", "name"],
  "properties": {
    "id": {
      "type": "integer",
      "format": "int64",
      "description": "The category ID"
    },
    "name": {
      "type": "string",
      "description": "The name of the category",
      "minLength": 1,
      "maxLength": 50
    },
    "description": {
      "type": "string",
      "description": "A description of the category"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "When the category was created"
    }
  }
}

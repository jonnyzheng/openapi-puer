{
  "type": "object",
  "title": "Pet",
  "description": "A pet in the pet store",
  "required": ["id", "name", "status"],
  "properties": {
    "id": {
      "type": "integer",
      "format": "int64",
      "description": "The pet ID"
    },
    "name": {
      "type": "string",
      "description": "The name of the pet",
      "minLength": 1,
      "maxLength": 100
    },
    "status": {
      "type": "string",
      "description": "The status of the pet",
      "enum": ["available", "pending", "sold"],
      "default": "available"
    },
    "categoryId": {
      "type": "integer",
      "format": "int64",
      "description": "The category ID of the pet"
    },
    "category": {
      "$ref": "#/components/schemas/Category"
    },
    "tags": {
      "type": "array",
      "description": "Tags associated with the pet",
      "items": {
        "type": "string"
      }
    },
    "photoUrl": {
      "type": "string",
      "format": "uri",
      "description": "URL to a photo of the pet"
    },
    "age": {
      "type": "integer",
      "description": "Age of the pet in years"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "When the pet was created"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "When the pet was last updated"
    }
  }
}

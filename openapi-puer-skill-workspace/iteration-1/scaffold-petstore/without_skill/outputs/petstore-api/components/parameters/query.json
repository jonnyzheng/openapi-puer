{
  "limit": {
    "name": "limit",
    "in": "query",
    "description": "Maximum number of items to return",
    "required": false,
    "schema": {
      "type": "integer",
      "format": "int32",
      "default": 20,
      "minimum": 1,
      "maximum": 100
    }
  },
  "offset": {
    "name": "offset",
    "in": "query",
    "description": "Number of items to skip",
    "required": false,
    "schema": {
      "type": "integer",
      "format": "int32",
      "default": 0,
      "minimum": 0
    }
  },
  "status": {
    "name": "status",
    "in": "query",
    "description": "Filter pets by status",
    "required": false,
    "schema": {
      "type": "string",
      "enum": ["available", "pending", "sold"]
    }
  }
}

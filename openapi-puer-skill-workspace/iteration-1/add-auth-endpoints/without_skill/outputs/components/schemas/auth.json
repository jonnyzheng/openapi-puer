{
  "components": {
    "schemas": {
      "LoginRequest": {
        "type": "object",
        "title": "Login Request",
        "required": ["email", "password"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "description": "User email address"
          },
          "password": {
            "type": "string",
            "format": "password",
            "description": "User password"
          }
        }
      },
      "RegisterRequest": {
        "type": "object",
        "title": "Register Request",
        "required": ["username", "email", "password"],
        "properties": {
          "username": {
            "type": "string",
            "minLength": 3,
            "maxLength": 50,
            "description": "Unique username"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "User email address"
          },
          "password": {
            "type": "string",
            "format": "password",
            "minLength": 8,
            "description": "User password (minimum 8 characters)"
          }
        }
      },
      "AuthToken": {
        "type": "object",
        "title": "Auth Token",
        "required": ["token", "type"],
        "properties": {
          "token": {
            "type": "string",
            "description": "JWT access token"
          },
          "type": {
            "type": "string",
            "enum": ["Bearer"],
            "description": "Token type"
          },
          "expiresIn": {
            "type": "integer",
            "description": "Token expiration time in seconds"
          }
        }
      },
      "AuthResponse": {
        "type": "object",
        "title": "Auth Response",
        "required": ["message", "data"],
        "properties": {
          "message": {
            "type": "string",
            "description": "Response message"
          },
          "data": {
            "$ref": "#/components/schemas/AuthToken"
          }
        }
      },
      "LogoutResponse": {
        "type": "object",
        "title": "Logout Response",
        "required": ["message"],
        "properties": {
          "message": {
            "type": "string",
            "description": "Logout confirmation message"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "title": "Error Response",
        "required": ["message"],
        "properties": {
          "message": {
            "type": "string",
            "description": "Error message"
          },
          "code": {
            "type": "string",
            "description": "Error code"
          }
        }
      }
    }
  }
}

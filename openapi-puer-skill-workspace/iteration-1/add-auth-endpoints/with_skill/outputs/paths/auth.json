{
  "openapi": "3.1.1",
  "info": {
    "title": "auth",
    "version": "1.0.0",
    "description": ""
  },
  "servers": [],
  "paths": {
    "/auth/login": {
      "post": {
        "summary": "Login user",
        "operationId": "auth-login",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "../components/schemas/auth.json#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful authentication",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../components/schemas/auth.json#/components/schemas/LoginResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials"
          }
        }
      }
    },
    "/auth/register": {
      "post": {
        "summary": "Register user",
        "operationId": "auth-register",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "../components/schemas/auth.json#/components/schemas/RegisterRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User registered successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../components/schemas/auth.json#/components/schemas/RegisterResponse"
                }
              }
            }
          },
          "409": {
            "description": "Email or username already exists"
          }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "summary": "Logout user",
        "operationId": "auth-logout",
        "tags": ["Auth"],
        "parameters": [],
        "responses": {
          "204": {
            "description": "Successfully logged out"
          },
          "401": {
            "description": "Not authenticated"
          }
        }
      }
    }
  }
}

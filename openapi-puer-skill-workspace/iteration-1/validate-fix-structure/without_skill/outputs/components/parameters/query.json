{
  "components": {
    "parameters": {
      "PageParam": {
        "name": "page",
        "in": "query",
        "description": "Page number for pagination",
        "schema": {
          "type": "integer",
          "minimum": 1,
          "default": 1
        },
        "example": 1
      },
      "PageSizeParam": {
        "name": "pageSize",
        "in": "query",
        "description": "Number of items per page",
        "required": false,
        "schema": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 20
        },
        "example": 20
      },
      "SearchParam": {
        "name": "q",
        "in": "query",
        "description": "Search keyword",
        "required": false,
        "schema": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "example": "hello"
      },
      "SortByParam": {
        "name": "sortBy",
        "in": "query",
        "description": "Field to sort results by",
        "required": false,
        "schema": {
          "type": "string",
          "enum": [
            "created_at",
            "updated_at",
            "name",
            "price"
          ],
          "default": "created_at"
        }
      },
      "SortOrderParam": {
        "name": "order",
        "in": "query",
        "description": "Sort direction",
        "required": false,
        "schema": {
          "type": "string",
          "enum": [
            "asc",
            "desc"
          ],
          "default": "desc"
        }
      },
      "FilterStatusParam": {
        "name": "status",
        "in": "query",
        "description": "Filter by status",
        "required": false,
        "schema": {
          "type": "string",
          "enum": [
            "active",
            "inactive",
            "pending",
            "archived"
          ]
        },
        "example": "active"
      },
      "FilterTagsParam": {
        "name": "tags",
        "in": "query",
        "description": "Filter by tags (comma-separated)",
        "required": false,
        "schema": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "style": "form",
        "explode": false,
        "example": [
          "electronics",
          "sale"
        ]
      },
      "FilterDateFromParam": {
        "name": "from",
        "in": "query",
        "description": "Filter results from this date",
        "required": false,
        "schema": {
          "type": "string",
          "format": "date"
        },
        "example": "2026-01-01"
      },
      "FilterDateToParam": {
        "name": "from",
        "in": "query",
        "description": "Filter results until this date",
        "required": false,
        "schema": {
          "type": "string",
          "format": "date"
        },
        "example": "2026-12-31"
      },
      "FieldsParam": {
        "name": "fields",
        "in": "query",
        "description": "Comma-separated list of fields to include in response",
        "required": false,
        "schema": {
          "type": "string"
        },
        "example": "id,name,price,status",
        "deprecated": true
      }
    }
  }
}
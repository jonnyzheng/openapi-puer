        ],
        "deprecated": true,
        "operationId": "new-product",
        "parameters": [
          {
            "name": "jack",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "raining",
            "in": "header",
            "schema": {
              "type": "string"
            },
            "required": true,
            "description": "下雨了"
          },
          {
            "name": "lang",
            "in": "header",
            "schema": {
              "type": "string"
            },
            "description": "for i18n",
            "required": true
          },
          {
            "name": "122",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "sum": {
                    "type": "integer"
                  }
                },
                "required": [
                  "name",
                  "sum"
                ]
              }
            }
          }
        }
      }
    },
    "/": {
      "get": {
        "summary": "baidu",
        "operationId": "product-baidu",
        "parameters": [
          {
            "name": "jack",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "username",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "success": {
            "description": "用户更新成功（3.1 新增响应Cookie+多示例）",
            "headers": {
              "X-Request-ID": {
                "description": "请求唯一标识",
                "schema": {
                  "type": "string",
                  "pattern": "^[a-f0-9]{32}$"
                },
                "example": "a1b2c3d4e5f67890a1b2c3d4e5f67890"
              },
              "X-Response-Time": {
                "description": "服务器处理耗时(ms)",
                "schema": {
                  "type": "integer"
                },
                "example": 80
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "allOf": [
                    {
                      "$ref": "../components/responses/response.json/responses/successResponse/content/application~1json/schema"
                    },
                    {
                      "properties": {
                        "data": {
                          "$ref": "../components/schemas/user.json#/components/schemas/Product"
                        }
                      }
                    }
                  ]
                },
                "examples": {
                  "normal": {
                    "summary": "普通用户更新示例",
                    "value": {
                      "code": 200,
                      "message": "更新成功",
                      "data": {
                        "id": 1001,
                        "username": "zhangsan",
                        "update_time": "2026-02-11T12:30:45Z"
                      }
                    }
                  },
                  "vip_user": {
                    "summary": "VIP用户更新示例",
                    "value": {
                      "code": 200,
                      "message": "VIP用户信息更新成功",
                      "data": {
                        "id": 1002,
                        "username": "lisi_vip",
                        "update_time": "2026-02-11T13:00:00+08:00"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "参数错误（3.1 JSON Schema 约束）",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "enum": [
                        40001,
                        40002
                      ]
                    },
                    "message": {
                      "type": "string"
                    },
                    "errors": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "field": {
                            "type": "string"
                          },
                          "msg": {
                            "type": "string"
                          }
                        },
                        "additionalProperties": false
                      }
                    }
                  }
                },
                "example": {
                  "code": 40001,
                  "message": "邮箱格式不合法",
                  "errors": [
                    {
                      "field": "email",
                      "msg": "必须包含@符号"
                    }
                  ]
                }
              }
            }
          },
          "default": {
            "description": "未预期错误",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer"
                    },
                    "message": {
                      "type": "string"
                    },
                    "request_id": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "code": 99999,
                  "message": "系统异常",
                  "request_id": "req_9876543210"
                }
              }
            }
          }
        }
      }
    },
